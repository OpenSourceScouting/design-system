# Base URL or path where program marks are served from.
# Defaults to /marks/ if unset.
#
# Examples:
#   VITE_MARKS_BASE_URL=/marks/
#   VITE_MARKS_BASE_URL=/assets/brand/
#   VITE_MARKS_BASE_URL=https://cdn.example.org/scouting/
#
# Copy this file to .env.local (gitignored) and edit per environment.
# VITE_ prefix is required by Vite to expose the variable to client code.
VITE_MARKS_BASE_URL=/marks/
