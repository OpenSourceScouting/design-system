{
  "name": "@opensourcescouting/design-system",
  "version": "0.1.0",
  "type": "module",
  "description": "Reusable design system for Scouting America and its four program sub-brands: Cub Scouts, Scouts BSA, Venturing, Sea Scouts.",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    },
    "./tokens": {
      "types": "./dist/tokens.css.d.ts",
      "default": "./dist/tokens.css"
    },
    "./theme": {
      "default": "./dist/theme.css"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:css",
    "build:css": "node scripts/build-css.mjs",
    "build:demo": "cross-env BUILD_TARGET=demo vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "test-storybook --url http://127.0.0.1:6006",
    "test:visual:ci": "concurrently -k -s first -n SB,TEST \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "test:visual:update": "concurrently -k -s first -n SB,TEST \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006 -u\"",
    "pretest:visual": "playwright install chromium",
    "pretest:visual:ci": "playwright install chromium",
    "pretest:visual:update": "playwright install chromium",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "clean": "rm -rf dist storybook-static .vite tsconfig.tsbuildinfo tsconfig.node.tsbuildinfo",
    "maintenance:git": "bash scripts/git-maintenance.sh"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/cli": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-playwright": "^2.1.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "http-server": "^14.1.1",
    "jest-axe": "^10.0.0",
    "jest-image-snapshot": "^6.5.2",
    "jsdom": "^27.0.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "10.5.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.10"
  }
}
