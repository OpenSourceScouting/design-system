{
  "name": "@opensourcescouting/design-system",
  "version": "0.2.0-alpha.0",
  "type": "module",
  "description": "Reusable design system that themes the Scouting America brand and its four program sub-brands: Cub Scouts, Scouts BSA, Venturing, Sea Scouts. A community project, not affiliated with Scouting America.",
  "license": "MIT",
  "author": "Open Source Scouting",
  "keywords": [
    "scouting",
    "scouting-america",
    "cub-scouts",
    "design-system",
    "react",
    "tailwindcss",
    "shadcn",
    "components",
    "theming",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenSourceScouting/design-system.git"
  },
  "homepage": "https://github.com/OpenSourceScouting/design-system#readme",
  "bugs": {
    "url": "https://github.com/OpenSourceScouting/design-system/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    },
    "./tokens": {
      "types": "./dist/tokens.css.d.ts",
      "default": "./dist/tokens.css"
    },
    "./theme": {
      "default": "./dist/theme.css"
    },
    "./tokens.json": "./dist/tokens/tokens.json",
    "./tokens.scss": "./dist/tokens/tokens.scss",
    "./tokens.email.json": "./dist/tokens/tokens.email.json",
    "./email.css": "./dist/email/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "NOTICE.md"
  ],
  "scripts": {
    "preinstall": "node scripts/check-npm-version.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:css",
    "build:css": "node scripts/build-css.mjs",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:demo": "cross-env BUILD_TARGET=demo vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "clean": "rm -rf dist storybook-static .vite tsconfig.tsbuildinfo tsconfig.node.tsbuildinfo",
    "maintenance:git": "bash scripts/git-maintenance.sh"
  },
  "engines": {
    "node": "^22.12.0 || >=24.0.0",
    "npm": ">=11"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "overrides": {
    "aria-query": "^5.3.2"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/addon-vitest": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@tailwindcss/cli": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "cross-env": "^10.1.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semantic-release": "^25.0.8",
    "storybook": "10.5.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
